# Set in CI/CD before npm run build (public in bundle — API URLs only, not secrets)

VITE_APPHUB_BACKEND_URL=https://api.yourcompany.com/api/knf/apphub
VITE_APPHUB_CORE_URL=https://api.yourcompany.com/api/knf

# Parent product origins allowed to postMessage token / language / theme
VITE_APPHUB_PARENT_ORIGINS=https://app.yourcompany.com

# Laravel backend (not this file) — hosted app CSP frame-ancestors when product embeds Hub:
# APPHUB_ALLOWED_HUB_ORIGINS=https://apphub.yourcompany.com
# APPHUB_ALLOWED_PRODUCT_ORIGINS=https://app.yourcompany.com
# Local dev defaults: hub :5173, product :3000 (see hub-host-starter README)

# Optional — host integrator internal bridge docs
# VITE_APPHUB_HOST_ACCESS_SECRET=

# Local dev only — open http://localhost:5173 directly (npm run dev), without product iframe
# VITE_APPHUB_DEV_LOGIN_URL=http://127.0.0.1:8000/api/user/login?user_id=1
# VITE_APPHUB_DEV_TOKEN=
