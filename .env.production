# Injected from GitHub secrets at build time (public API URLs in bundle — not user tokens)

VITE_APPHUB_BACKEND_URL=
VITE_APPHUB_CORE_URL=

# company-vuejs origins allowed to postMessage session into Hub iframe
VITE_APPHUB_PARENT_ORIGINS=

# Optional — host integrator internal bridge docs
# VITE_APPHUB_HOST_ACCESS_SECRET=
